# Dependencies
node_modules/

# Build output (regenerate with `npm run build` / `npm run package`)
dist/
dist-ssr/

# Lambda deployment zips (regenerate with `npm run package` in each backend/* folder)
*.zip

# Environment variables — real config lives only in .env, never commit it.
# .env.example files (with placeholder values) are meant to be committed.
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS
.DS_Store

# Editor
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
