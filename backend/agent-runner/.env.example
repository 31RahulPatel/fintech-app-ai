# Lambda environment variables (set these in the Lambda console -> Configuration -> Environment variables)

AGENTS_TABLE=FintechOps-Agents
EXECUTION_HISTORY_TABLE=FintechOps-ExecutionHistory

# Nova isn't available in every region — if it's not offered in this Lambda's own
# region (e.g. ap-south-1), set BEDROCK_REGION to one that has it (us-east-1, us-east-2,
# us-west-2, ...) and make sure the IAM role's bedrock:InvokeModel resources match.
BEDROCK_REGION=us-east-1

# Cross-region inference profile ID (required for Nova in most accounts) —
# must match the inference-profile ARN granted in the execution role's IAM policy.
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# mock (default, offline) | live (real prices via NSE + Yahoo Finance + CoinGecko + News API;
# see src/services/marketData/liveProvider.ts). Each source falls back to mock per-instrument
# if it fails, so this is safe to enable even if a key below is missing.
MARKET_DATA_PROVIDER=mock

# Free key from newsapi.org — used for real headlines when MARKET_DATA_PROVIDER=live.
# Leave unset to fall back to the mock headlines.
NEWS_API_KEY=

# Must be a verified SES identity (email or domain) in the same account/region
SES_SENDER_EMAIL=reports@fintechops.example.com
