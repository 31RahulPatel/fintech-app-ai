# AWS region
VITE_AWS_REGION=

# Cognito (User Pools console -> App integration). Must be a PUBLIC app client
# (no client secret) — amazon-cognito-identity-js can't compute SECRET_HASH.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# API Gateway invoke URL (Lambda 1 - schedule-api), e.g. https://xxxx.execute-api.ap-south-1.amazonaws.com/prod
VITE_API_BASE_URL=